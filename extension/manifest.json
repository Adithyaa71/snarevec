{
  "manifest_version": 3,
  "name": "SnareVec",
  "description": "Capture web pages, embed them locally, and feed your self-hosted agents' RAG.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SnareVec — feed your agents"
  },
  "options_page": "options/options.html",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
